#!/usr/bin/env sh
set -e

echo 'husky (pre-commit): running lint-staged'
yarn lint-staged

STAGED_FILES=$(git diff --cached --name-only)

# Check for docs redirect changes
if printf '%s\n' "$STAGED_FILES" | grep -E '^(data/docs/.*\.mdx|next\.config\.js|scripts/check-doc-redirects\.js)$' >/dev/null; then
  echo 'husky (pre-commit): verifying docs redirects'
  yarn check:doc-redirects
else
  echo 'husky (pre-commit): skipping docs redirect check (no relevant changes staged)'
fi

# Check for docs metadata
if printf '%s\n' "$STAGED_FILES" | grep -E '^data/docs/.*\.mdx$' >/dev/null; then
  echo 'husky (pre-commit): validating docs metadata'
  HUSKY_PRE_COMMIT=true yarn check:docs-metadata
else
  echo 'husky (pre-commit): skipping docs metadata check (no documentation changes staged)'
fi

# Auto-fix stale/redirected URLs
if printf '%s\n' "$STAGED_FILES" | grep -qE '^next\.config\.js$'; then
  echo 'husky (pre-commit): next.config.js changed — scanning all files for stale URLs'
  node scripts/check-stale-urls.js --fix --all --stage-fixes
elif printf '%s\n' "$STAGED_FILES" | grep -qE '^(components/|app/|constants/|hooks/|utils/|data/).*\.(tsx|ts|jsx|js|mdx)$'; then
  echo 'husky (pre-commit): auto-fixing stale/redirected URLs in staged files'
  node scripts/check-stale-urls.js --fix --staged
else
  echo 'husky (pre-commit): skipping stale URL check (no relevant changes staged)'
fi

# Check CMS-synced content assets
if printf '%s\n' "$STAGED_FILES" | grep -E '^data/(faqs|case-study|opentelemetry|comparisons|guides|blog)/.*\.mdx?$' >/dev/null; then
  echo 'husky (pre-commit): checking CMS content assets'
  node scripts/check-cms-assets.js
else
  echo 'husky (pre-commit): skipping CMS asset check (no migrated content changes staged)'
fi