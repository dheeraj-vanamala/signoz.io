    "lodash": "^4.18.0",
    "@sentry/browser": "^7.119.1",
    "pliny/js-yaml": "^4.1.1",
    "qs": "^6.14.2",
    "yaml": "^2.8.3",
    "postcss": "^8.5.10"
  },
  "lint-staged": {
    "*.+(js|jsx|ts|tsx)": [
      "eslint --fix"
    ],
    "*.+(js|jsx|ts|tsx|json|css)": [
      "prettier --write"
    ]
  }
}
