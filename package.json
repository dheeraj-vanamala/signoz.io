{
  "name": "signoz-web",
  "version": "2.2.0",
  "private": true,
  "scripts": {
    "start": "next dev",
    "dev": "cross-env INIT_CWD=$PWD next dev",
    "build": "cross-env INIT_CWD=$PWD NODE_OPTIONS='--max-old-space-size=8192' next build && cross-env NODE_OPTIONS='--experimental-json-modules' node ./scripts/postbuild.mjs",
    "serve": "next start",
    "analyze": "cross-env ANALYZE=true next build",
    "lint": "next lint --fix --dir pages --dir app --dir components --dir lib --dir layouts --dir scripts",
    "check:doc-redirects": "node scripts/check-doc-redirects.js",
    "test:doc-redirects": "node --test tests/doc-redirects.test.js",
    "check:docs-metadata": "node scripts/check-docs-metadata.js",
    "test:docs-metadata": "node --test tests/docs-metadata.test.js",
    "test:component-items": "node --test tests/component-items-sync.test.js",
    "prepare": "husky"
  },
  "dependencies": {
    "@growthbook/growthbook": "^1.4.1",
    "@headlessui/react": "^2.0.3",
    "@next/bundle-analyzer": "^15.5.18",
    "@next/third-parties": "^15.5.18",
    "@radix-ui/react-popover": "^1.1.6",
    "@radix-ui/react-select": "^2.2.5",
    "@radix-ui/react-slider": "^1.2.2",
    "@radix-ui/react-tooltip": "^1.1.8",
    "@signozhq/badge": "^0.0.2",
    "@signozhq/design-tokens": "1.1.4",
    "@signozhq/pagination": "^0.0.1",
    "@stoplight/elements": "^9.0.11",
    "@tailwindcss/forms": "^0.5.7",
    "@tailwindcss/typography": "^0.5.12",
    "@vercel/functions": "^2.2.8",
    "@vercel/speed-insights": "^1.3.1",
    "@vimeo/player": "^2.23.0",
    "algoliasearch": "^5.37.0",
    "autoprefixer": "^10.4.13",
    "contentlayer2": "0.5.5",
    "date-fns": "^3.6.0",
    "dompurify": "^3.4.0",
    "framer-motion": "^11.13.5",
    "github-slugger": "^2.0.0",
    "gray-matter": "^4.0.2",
    "hast-util-from-dom": "^5.0.1",
    "hast-util-from-html-isomorphic": "^2.0.0",
    "js-cookie": "^3.0.7",
    "lucide-react": "0.540.0",
    "next": "^15.5.18",
    "next-contentlayer2": "0.5.5",
    "next-mdx-remote": "^6.0.0",
    "pliny": "0.4.1",
    "postcss": "^8.5.10",
    "qs": "^6.14.2",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-ga4": "^2.1.0",
    "react-icons": "^5.5.0",
    "react-instantsearch": "^7.16.3",
    "react-lite-yt-embed": "^1.2.7",
    "react-markdown": "^9.0.1",
    "react-medium-image-zoom": "^5.4.5",
    "react-multi-carousel": "^2.8.5",
    "reading-time": "1.5.0",
    "recharts": "^3.8.1",
    "rehype-autolink-headings": "^7.1.0",
    "rehype-preset-minify": "7.0.0",
    "rehype-prism-plus": "^2.0.0",
    "rehype-remark": "^10.0.1",
    "rehype-slug": "^6.0.0",
    "remark-gfm": "^4.0.0",
    "remark-math": "^6.0.0",
